# Normalize line endings across platforms
* text=auto

# Force LF for scripts and source files
*.sh text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.nr text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.env text eol=lf

# Binaries
*.wasm binary
*.bin binary
*.gz binary
*.png binary
*.jpg binary
