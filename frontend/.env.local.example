# ─── Privy Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# ─── Stellar ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Contract IDs (from .env.contracts after deploy) ─────────────────────────
NEXT_PUBLIC_RBAC_CONTRACT_ID=C...
NEXT_PUBLIC_TRACEABILITY_CONTRACT_ID=C...
NEXT_PUBLIC_ZK_MEDICAL_CONTRACT_ID=C...

# ─── Passkey Kit / Smart Wallet ───────────────────────────────────────────────
NEXT_PUBLIC_WALLET_WASM_HASH=...

# ─── Launchtube (SDF fee relay for Testnet) ───────────────────────────────────
LAUNCHTUBE_URL=https://testnet.launchtube.xyz
LAUNCHTUBE_JWT=...

# ─── Backend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── Firebase (client-side) ───────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=...
NEXT_PUBLIC_FIREBASE_PROJECT_ID=trustleaf-mvp

# ─── Resend (email transaccional) ─────────────────────────────────────────────
# Obtener en https://resend.com — dominio noreply@trustleaf.cl debe estar verificado
RESEND_API_KEY=re_...

# ─── Cron Secret (protege /api/cron/* y /api/patient/reminder) ────────────────
# Generar con: openssl rand -hex 32
CRON_SECRET=

# ─── URL pública de la app (para links en emails) ─────────────────────────────
NEXT_PUBLIC_APP_URL=https://trustleaf.cl
