# ── Stellar ──────────────────────────────────────────────────────────────────
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# ── Sponsor (fee-bumper) ──────────────────────────────────────────────────────
# Generate with: stellar keys generate sponsor --network testnet
# Then fund with Friendbot
SPONSOR_SECRET_KEY=S...

# ── Contract IDs (from deploy-contracts.sh output) ───────────────────────────
RBAC_CONTRACT_ID=C...
TRACEABILITY_CONTRACT_ID=C...
ZK_MEDICAL_CONTRACT_ID=C...

# ── ZK Circuit artifacts ──────────────────────────────────────────────────────
CIRCUIT_BYTECODE_PATH=../circuits/blind_prescription/target/blind_prescription.json
VK_PATH=../circuits/blind_prescription/target/vk.bin

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=trustleaf-mvp
# Either path to service account JSON file:
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or inline JSON (for production env vars):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Mercury/Zephyr ────────────────────────────────────────────────────────────
MERCURY_API_KEY=...
MERCURY_BACKEND_URL=https://api.mercurydata.app:2083

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
